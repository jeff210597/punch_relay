# Copy this file to .env or set these variables in Windows environment variables.
# Do not upload real secrets to GitHub.

DISCORD_TOKEN=put_your_discord_bot_token_here
NOTIFY_CHANNEL_ID=put_discord_channel_id_here
EHR_BASE=http://your-ehr-host
ADMIN_ALERT_CHANNEL_ID=put_admin_alert_channel_id_here
# Exit for NSSM recovery after this many seconds disconnected from Discord.
DISCONNECT_RESTART_SECONDS=300
